# Copy to .env and fill in. Both the Python backend (SQLAlchemy) and
# scripts/refresh-picks.sh read this file. Neon format:
#   postgresql+psycopg://USER:PASS@HOST/DB?sslmode=require
# Local Docker (docker-compose.yml default):
#   postgresql+psycopg://hrp:hrp@localhost:5432/hrp
DATABASE_URL=postgresql+psycopg://hrp:hrp@localhost:5432/hrp
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
THE_ODDS_API_KEY=
THE_ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
THE_ODDS_API_REGIONS=us
PROP_LINE_API_KEY=
PROP_LINE_BASE_URL=https://api.prop-line.com/v1
