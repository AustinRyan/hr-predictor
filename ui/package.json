{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:ranking-sort": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-ranking-sort.mjs",
    "music:promo": "node remotion/generate-promo-music.mjs",
    "remotion": "npm run music:promo && remotion studio remotion/index.ts --port=3001",
    "render:promo": "npm run music:promo && remotion render remotion/index.ts HomerunPromo out/homerun-promo.mp4",
    "still:promo": "npm run music:promo && remotion still remotion/index.ts HomerunPromo out/homerun-promo-poster.png --frame=270"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@remotion/cli": "4.0.454",
    "lucide-react": "^1.9.0",
    "next": "16.2.4",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remotion": "4.0.454"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
